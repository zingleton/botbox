# ─────────────────────────────────────────────────────────────
# Botbox — Tauri (Rust backend + web frontend) .gitignore
# ─────────────────────────────────────────────────────────────

# ── Rust / Cargo (src-tauri) ──────────────────────────────────
/target/
src-tauri/target/
**/*.rs.bk
*.pdb
# Note: Cargo.lock IS committed for an application (reproducible builds).

# ── Tauri build & generated artifacts ─────────────────────────
# Generated native mobile/desktop projects (regenerated by `tauri`)
src-tauri/gen/
# Bundled installers / app output
src-tauri/target/release/bundle/
*.app
*.dmg
*.AppImage
*.deb
*.rpm
*.msi
*.exe

# ── Tauri signing / updater keys (NEVER commit) ───────────────
.tauri/
*.key
*.pem
*.p12
*.keystore
tauri-updater.key*

# ── Node / frontend ───────────────────────────────────────────
node_modules/
dist/
dist-ssr/
build/
.vite/
.cache/
*.local
# Frontend lockfiles ARE committed (package-lock.json / pnpm-lock.yaml / yarn.lock)

# ── Environment & secrets (the app handles API keys) ──────────
.env
.env.*
!.env.example
*.secret

# ── Logs & debug ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# AI coding tools
# ─────────────────────────────────────────────────────────────

# ── Claude Code ───────────────────────────────────────────────
# Share project config (.claude/settings.json, commands, skills, .mcp.json,
# CLAUDE.md) but keep personal/local overrides and caches out of git.
.claude/settings.local.json
.claude/*.local.json
.claude/local/
.claude/projects/
.claude/todos/
.claude/shell-snapshots/
.claude/statsig/

# ── Codex (OpenAI) ────────────────────────────────────────────
# Share AGENTS.md; ignore local/runtime state.
.codex/
!AGENTS.md

# ── Generic agent / tool scratch ──────────────────────────────
.aider*
.cursor/
*.tmp
scratchpad/

# ── OS cruft ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editors / IDEs ────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
