# === Hetzner / Hermes deploy config ===
# Copy this file to ".env" and fill in the two secrets below.
#   cp .env.example .env
# .env is gitignored — never commit it.

# Hetzner Cloud API token (needs Read & Write).
# Create at: Hetzner Cloud Console -> your project -> Security -> API Tokens
HCLOUD_TOKEN=

# OpenRouter API key -> https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Everything below is optional; the defaults match what was chosen for this
# deploy. Uncomment to override.
# ---------------------------------------------------------------------------

# SSH keypair used to reach the bot. If the public key does not exist it is
# generated (ed25519) on first ./provision.sh run.
#SSH_KEY_PATH=$HOME/.ssh/botbox_hermes
#SSH_KEY_NAME=botbox-hermes
#REMOTE_USER=hermes

# Server sizing / placement.  US East (Ashburn) uses the AMD "CPX" line.
#SERVER_NAME=hermes-bot-1
#SERVER_TYPE=cpx21          # 3 vCPU / 4 GB / 80 GB  (~$0.013/hr, ~$8/mo)
#SERVER_LOCATION=ash        # Ashburn, VA. (hil = Hillsboro OR, fsn1 = EU)
#SERVER_IMAGE=ubuntu-24.04

# Hermes
#HERMES_MODEL=anthropic/claude-sonnet-4.5
#DASHBOARD_PORT=9119        # remote port Hermes dashboard binds (127.0.0.1 only)
#LOCAL_TUNNEL_PORT=9119     # local port ./dashboard.sh forwards it to
